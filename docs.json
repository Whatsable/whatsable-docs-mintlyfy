              "guides/whatsable/n8n",
              "guides/whatsable/api-documentation"
            ]
          },
          {
            "group": "Notifyer System",
            "pages": [
              "guides/notifyer-system/embedding-process",
              "guides/notifyer-system/zapier-overview",
              "guides/notifyer-system/make-overview",
              "guides/notifyer-system/n8n-overview",
              "guides/notifyer-system/pipedrive-overview",
              "guides/notifyer-system/monday-overview",
              {
                "group": "API Documentation",
                "pages": [
                  "guides/notifyer-system/api/get-templates",
                  "guides/notifyer-system/api/template-message",
                  "guides/notifyer-system/api/non-template-message",
                  "guides/notifyer-system/api/incoming-message"
